{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_ORIGIN": "https://www.usefocus.me"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_ORIGIN": "https://www.usefocus.me"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "D8UM897B2T",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "bundleIdentifier": "me.usefocus.app.expo"
      }
    }
  }
}
