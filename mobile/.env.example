# Configuración pública para la app Expo (Focus mobile).
#
# IMPORTANTE
# ----------
# Solo variables `EXPO_PUBLIC_*` se inyectan en el bundle del cliente.
# NUNCA pongas acá secrets backend (service role key, ANTHROPIC_API_KEY,
# RESEND_API_KEY, VAPID_PRIVATE_KEY, APNS_PRIVATE_KEY, CRON_SECRET, etc).
# Esos viven solo en el backend Vercel y se acceden desde /api/*.
#
# Cómo usar:
#   cp mobile/.env.example mobile/.env
#   # luego completá los valores y reiniciá `expo start`

# Supabase — los mismos valores que VITE_SUPABASE_* de la app web.
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Origen de las APIs de Vercel. En producción se usa https://www.usefocus.me.
# Para desarrollo apuntando a un preview deployment o `vercel dev` local,
# cambialo acá.
EXPO_PUBLIC_API_ORIGIN=https://www.usefocus.me
